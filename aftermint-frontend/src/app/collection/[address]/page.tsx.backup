// Mock data for collection - in a real app this would come from an API
// const collections = { ... }; // REMOVE THIS OLD MOCK OBJECT

// Updated to use the Collection type from allCollections
interface Collection {
  name: string;
  contract: string;
  logo?: string;
  banner?: string;
  website?: string;
  twitter?: string;
  telegram?: string;
  description?: string;
  floorPrice?: number;
  volume24h?: number;
  volume7d?: number;
  totalSupply: number; // Changed from items to totalSupply
  holders: number; // Changed from owners to holders
  chainId: number;
}

const generateMockNFTs = (collectionData: Collection | undefined, count: number = 20) => {
  if (!collectionData) return [];
  
  console.log(`[GenerateMockNFTs] Creating ${count} mock NFTs for collection:`, collectionData.name);

  return Array.from({ length: count }, (_, i) => {
    const tokenId = i + 1;
    
    // Create a realistic distribution: ~25% listed with varied prices
    const isListed = Math.random() < 0.25; // 25% chance of being listed
    
    // Generate realistic prices around the floor price
    const baseFloorPrice = (collectionData as any).floorPrice || 0.1;
    let price = null;
    
    if (isListed) {
      // Generate varied prices: some at floor, some higher
      const priceVariation = Math.random();
      if (priceVariation < 0.3) {
        // 30% at or near floor price
        price = baseFloorPrice * (0.95 + Math.random() * 0.1); // 0.95x to 1.05x floor
      } else if (priceVariation < 0.7) {
        // 40% moderately above floor
        price = baseFloorPrice * (1.1 + Math.random() * 2); // 1.1x to 3.1x floor
      } else {
        // 30% significantly above floor
        price = baseFloorPrice * (3 + Math.random() * 7); // 3x to 10x floor
      }
      
      // Ensure NFT #118 has specific price for testing
      if (tokenId === 118) {
        price = 555.0;
        console.log(`[GenerateMockNFTs] ✅ Setting NFT #118 with test price: ${price} BASED`);
      }
      
      // Round to 3 decimal places
      price = parseFloat(price.toFixed(3));
    }
    
    // Force NFT #118 to be listed for testing
    if (tokenId === 118) {
      price = price || 555.0;
      const finalNFT = {
        id: tokenId,
        tokenId: tokenId,
        name: `${collectionData.name} #${tokenId}`,
        image: `https://picsum.photos/seed/${(collectionData as any).contract || collectionData.name}${tokenId}/500/500`,
        price: price,
        isListed: true,
        listing: {
          active: true,
          price: String(price),
          seller: `0x${Math.random().toString(16).substring(2, 42)}`,
          nftContract: (collectionData as any).contract || 'unknown',
          tokenId: tokenId
        },
        seller: `0x${Math.random().toString(16).substring(2, 42)}`,
        owner: `0x${Math.random().toString(16).substring(2, 42)}`,
        attributes: [
          { trait_type: "Background", value: ["Blue", "Green", "Purple", "Gold", "Silver"][Math.floor(Math.random() * 5)] },
          { trait_type: "Rarity", value: ["Common", "Uncommon", "Rare", "Epic", "Legendary"][Math.floor(Math.random() * 5)] }
        ]
      };
      
      console.log(`[GenerateMockNFTs] ✅ Created NFT #118 with listing:`, {
        tokenId: finalNFT.tokenId,
        isListed: finalNFT.isListed,
        price: finalNFT.price,
        listing: finalNFT.listing
      });
      
      return finalNFT;
    }
    
    const nftData = {
      id: tokenId,
      tokenId: tokenId,
      name: `${collectionData.name} #${tokenId}`,
      image: `https://picsum.photos/seed/${(collectionData as any).contract || collectionData.name}${tokenId}/500/500`,
      price: price,
      isListed: isListed,
      listing: isListed ? {
        active: true,
        price: String(price),
        seller: `0x${Math.random().toString(16).substring(2, 42)}`,
        nftContract: (collectionData as any).contract || 'unknown',
        tokenId: tokenId
      } : null,
      seller: isListed ? `0x${Math.random().toString(16).substring(2, 42)}` : null,
      owner: `0x${Math.random().toString(16).substring(2, 42)}`,
      attributes: [
        { trait_type: "Background", value: ["Blue", "Green", "Purple", "Gold", "Silver"][Math.floor(Math.random() * 5)] },
        { trait_type: "Rarity", value: ["Common", "Uncommon", "Rare", "Epic", "Legendary"][Math.floor(Math.random() * 5)] }
      ]
    };
    
    return nftData;
  });
};

// Sort options
type SortOption = 'price_low_high' | 'price_high_low' | 'token_id_asc' | 'token_id_desc';

// Enhanced function to fetch ALL NFTs with proper marketplace listing detection
const fetchRealNFTs = async (
  collectionAddress: string, 
  page: number = 1, 
  itemsPerPage: number = 20,
  sortBy: SortOption = 'price_low_high',
  searchQuery?: string,
  showOnlyListed: boolean = false
) => {
  try {
    console.log(`[FetchRealNFTs] Starting real blockchain fetch for collection ${collectionAddress}`);
    
    const provider = getBasedAIProvider();
    
    // Get collection info
      const realActivity = await getCollectionActivity(address, provider, 20);
      
      console.log(`[CollectionPage] Found ${realActivity.length} real activity items for collection`);
      setCollectionActivity(realActivity);
      
    } catch (error) {
      console.error('[CollectionPage] Error fetching collection activity:', error);
      setCollectionActivity([]);
    } finally {
      setActivityLoading(false);
    }
  };

  // Function to fetch real collection statistics from BasedAI explorer API
  const fetchRealCollectionStats = async (collectionAddress: string) => {
    try {
      console.log(`[CollectionStats] Fetching real collection stats for ${collectionAddress}`);
      
      // Get real collection data from BasedAI explorer
      const response = await fetch(`https://explorer.bf1337.org/api/v2/tokens/${collectionAddress}`);
      if (!response.ok) {
        throw new Error(`Failed to fetch collection stats: ${response.status}`);
      }
      
      const explorerData = await response.json();
      console.log('[CollectionStats] Real explorer data:', explorerData);
      
      // ALSO get real total supply directly from the NFT contract
      let contractTotalSupply = null;
      try {
        const provider = getBasedAIProvider();
        
        // Standard ERC721 totalSupply method
        const nftContract = new ethers.Contract(
          collectionAddress,
          [
            "function totalSupply() view returns (uint256)",
            "function name() view returns (string)",
            "function symbol() view returns (string)"
          ],
          provider
        );
        
        const [totalSupply, contractName, symbol] = await Promise.all([
          nftContract.totalSupply().catch(() => null),
          nftContract.name().catch(() => null),
          nftContract.symbol().catch(() => null)
        ]);
        
        if (totalSupply) {
          contractTotalSupply = parseInt(totalSupply.toString());
          console.log(`[CollectionStats] ✅ Contract total supply: ${contractTotalSupply}`);
        }
        
        if (contractName) {
          console.log(`[CollectionStats] ✅ Contract name: ${contractName}`);
        }
        
      } catch (contractError) {
        console.warn('[CollectionStats] Failed to fetch from contract:', contractError);
      }
      
      // Use real data from explorer API and contract
      const realStats = {
        totalSupply: contractTotalSupply || parseInt(explorerData.total_supply || '0'), // Prefer contract data
        holders: parseInt(explorerData.holders || '0'),     // Real holders count  
        floorPrice: undefined, // No floor price data in explorer API yet
        volume24h: undefined,  // No volume data in explorer API yet
        volume7d: undefined    // No volume data in explorer API yet
      };
      
      console.log('[CollectionStats] ✅ Final real collection stats:', realStats);
      
      // Update collection with real data
      setCollection(prev => prev ? {
        ...prev,
        totalSupply: realStats.totalSupply,
        holders: realStats.holders,
        floorPrice: realStats.floorPrice,
        volume24h: realStats.volume24h,
        volume7d: realStats.volume7d
      } : null);
      
    } catch (error) {
      console.error('[CollectionStats] Error fetching real collection stats:', error);
    }
  };

  const fetchCollectionStats = async () => {
    if (!address) return;
    
    setStatsLoading(true);
    try {
      console.log(`[CollectionPage] Fetching collection statistics for ${address}`);
      
      const provider = getBasedAIProvider();
      
      // Get real collection data from explorer API (updates state directly)
      await fetchRealCollectionStats(address);
      
      // Use existing working methods only - remove the non-existent contract methods
      const [floorPrice, volume24h, volume7d, totalVolume] = await Promise.all([
        getCollectionFloorPrice(address, provider).catch(() => null),
        getCollectionVolume(address, provider, 1).catch(() => 0),
        getCollectionVolume(address, provider, 7).catch(() => 0),
        getCollectionVolume(address, provider).catch(() => 0)
      ]);
      
      console.log(`[CollectionPage] Collection stats fetched:`, {
        floorPrice,
        volume24h,
        volume7d,
        totalVolume
      });
      
      setCollectionStats({
        floorPrice,
        volume24h,
        volume7d,
        totalVolume,
        realHoldersCount: null // Set to null since we get the real holders count through the collection state now
      });
      
    } catch (error) {
      console.error('[CollectionPage] Error fetching collection statistics:', error);
    } finally {
      setStatsLoading(false);
    }
  };

  // Enhanced main data fetching useEffect with proper pagination and search
  useEffect(() => {
    if (!address) {
      setLoading(false);
      setError("Collection address is missing.");
      setNfts([]);
      setCollection(null);
      return;
    }

    let isMounted = true;
    const loadData = async () => {
      if (!isMounted) return;
      setLoading(true);
      setError(null);
      
      // Always use @/data/collections.ts for known collections
      const basedCollection = basedCollections.find(c => c.id.toLowerCase() === address.toLowerCase());
      if (basedCollection) {
        const formattedCollection = {
          name: basedCollection.name,
          contract: basedCollection.id,
          logo: basedCollection.logoUrl,
          banner: basedCollection.bannerUrl,
          website: basedCollection.website,
          twitter: basedCollection.twitter,
          telegram: basedCollection.telegram,
          description: `Collection for ${basedCollection.name}`,
          floorPrice: basedCollection.floorPrice || 0.1,
          volume24h: basedCollection.volume24h || 0,
          totalSupply: basedCollection.items || 1000,
          holders: basedCollection.owners || 500,
          chainId: 8453
        };
        setCollection(formattedCollection);
      }

      try {
        const result = await fetchRealNFTs(
          address,
          currentPage,
          itemsPerPage,
          sortBy,
          searchQuery,
          showOnlyListed
        );

        if (isMounted) {
          setNfts(result.nfts);
          setTotalNFTs(result.totalItems);
          setHasMoreNFTs(result.hasMore);
        }
      } catch (error) {
        if (isMounted) {
          console.error("Failed to load collection data:", error);
          setError("Failed to load collection data. Please try again.");
        }
      } finally {
        if (isMounted) {
          setLoading(false);
        }
      }
    };

    loadData();
    return () => { isMounted = false; };
  }, [address, currentPage, itemsPerPage, sortBy, searchQuery, showOnlyListed]);

  // Fetch activity when activity tab is selected 
  useEffect(() => {
    if (currentTab === 'activity' && collectionActivity.length === 0 && !activityLoading) {
      fetchCollectionActivity();
    }
  }, [currentTab, address]);

  // Fetch collection statistics when component mounts
  useEffect(() => {
    if (address && !statsLoading) {
      fetchCollectionStats();
    }
  }, [address]);

  // Pagination logic - updated for server-side pagination
  const totalPages = Math.ceil((totalNFTs || 0) / itemsPerPage);
  // Use nfts directly from server-side filtering and sorting
  const paginatedNFTs = nfts;

  // Pagination controls
  const goToPage = (page: number) => {
    const newPage = Math.max(1, Math.min(page, totalPages));
    setCurrentPage(newPage);
    
    // Update URL with page number
    const newUrl = newPage > 1 ? 
      `/collection/${address}?page=${newPage}` : 
      `/collection/${address}`;
    router.push(newUrl);
    
    window.scrollTo({ top: 0, behavior: 'smooth' });
  };

  // Handle NFT interaction (buy/offer)
  const handleNFTInteraction = (nftData: any) => {
    setSelectedNFT(nftData);
    setIsModalOpen(true);
  };

  if (loading) {
    return <CollectionPageSkeleton />;
  }

  if (error) { // Check for error state first
    return (
      <div className="container mx-auto px-4 py-12 text-center">
        <h1 className="text-3xl font-bold mb-4">Error</h1>
        <p className="text-theme-text-secondary mb-8">{error}</p>
      </div>
    );
  }

  if (!collection) { // This should ideally be caught by the error state if not found
    return (
      <div className="container mx-auto px-4 py-12 text-center">
        <h1 className="text-3xl font-bold mb-4">Collection Not Found</h1>
        <p className="text-theme-text-secondary mb-8">
          The collection could not be loaded. It might not exist or there was an issue.
        </p>
      </div>
    );
  }

  return (
    <div className="container mx-auto">
      {/* Removed duplicate header and search bar */}

      {/* Collection Information - Removed banner, keeping just the info section */}
      <div className="mb-8 pt-8">
        <div className="container mx-auto px-4">
          <div className="glass-card rounded-xl border border-theme-border p-6 md:p-8">
            {/* Collection Logo and Title */}
            <div className="flex flex-col md:flex-row gap-6 items-center md:items-start">
              {/* Collection Logo */}
              <div className="w-24 h-24 rounded-xl border border-theme-background overflow-hidden flex-shrink-0 bg-theme-surface">
                <div 
                  className="w-full h-full bg-cover bg-center" 
                  style={{ backgroundImage: `url(${collection.logo})` }}
                />
              </div>
              
              {/* Collection Details - Main content */}
              <div className="flex-grow text-center md:text-left">
                <div className="flex flex-col md:flex-row md:items-center gap-2 mb-3">
                  <h1 className="text-2xl md:text-3xl font-bold text-theme-text-primary">{collection.name}</h1>
                  <div className="flex items-center justify-center md:justify-start gap-2">
                    <div 
                      className="flex items-center gap-1 text-sm text-theme-text-secondary cursor-pointer group"
                      onClick={() => handleCopy(collection.contract)}
                      title={collection.contract}
                    >
                      <span>{shortenAddress(collection.contract, 6)}</span>
                      <Copy size={14} className={`group-hover:text-theme-primary ${copied ? "text-theme-primary" : ""}`} />
                    </div>
                  </div>
                </div>
                
                {/* Collection Description */}
                <p className="text-theme-text-secondary mb-4 max-w-2xl">
                  {collection.description}
                </p>
              </div>
              
              {/* Collection Stats - Moved to right side */}
              <div className="flex flex-col gap-4 md:min-w-44 md:border-l md:border-theme-border md:pl-6">
                {/* Stats in horizontal row */}
                <div className="flex flex-row gap-4 md:gap-6 justify-center">
                  <div className="text-center">
                    <p className="text-xs text-theme-text-secondary uppercase">Floor</p>
                    <p className="font-bold text-theme-text-primary">
                      {(() => {
                        // Calculate floor price as lowest listed price from current NFTs
                        const listedNFTs = nfts.filter(nft => nft.isListed && nft.price && nft.price > 0);
                        if (listedNFTs.length === 0) {
                          return statsLoading ? '...' : 'No Listings';
                        }
                        const floorPrice = Math.min(...listedNFTs.map(nft => nft.price));
                        return `${floorPrice.toFixed(3)} BASED`;
                      })()}
                    </p>
                  </div>
                  <div className="text-center">
                    <p className="text-xs text-theme-text-secondary uppercase">Volume</p>
                    <p className="font-bold text-theme-text-primary">
                      {statsLoading ? '...' : collectionStats.volume24h ? `${collectionStats.volume24h.toFixed(1)} BASED` : 'N/A'}
                    </p>
                  </div>
                  <div className="text-center">
                    <p className="text-xs text-theme-text-secondary uppercase">Total Supply</p>
                    <p className="font-bold text-theme-text-primary">
                      {collection ? (collection.totalSupply || 'N/A') : 'N/A'}
                    </p>
                  </div>
                  <div className="text-center">
                    <p className="text-xs text-theme-text-secondary uppercase">Holders</p>
                    <p className="font-bold text-theme-text-primary">
                      {statsLoading ? '...' : collectionStats.realHoldersCount ? collectionStats.realHoldersCount : (collection?.holders || 'N/A')}
                    </p>
                  </div>
                </div>
                
                {/* Social links below the stats - Icon only */}
                <div className="flex flex-wrap gap-4 justify-center">
                  {collection.website && (
                    <a 
                      href={collection.website.startsWith('http') ? collection.website : `https://${collection.website}`}
                      target="_blank" 
                      rel="noopener noreferrer"
                      className="flex items-center justify-center w-9 h-9 rounded-full bg-theme-surface hover:bg-theme-primary hover:text-black transition-colors"
                      title="Website"
                    >
                      <Globe size={16} />
                    </a>
                  )}
                  {collection.twitter && (
                    <a 
                      href={collection.twitter}
                      target="_blank" 
                      rel="noopener noreferrer"
                      className="flex items-center justify-center w-9 h-9 rounded-full bg-theme-surface hover:bg-theme-primary hover:text-black transition-colors"
                      title="Twitter"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className="lucide lucide-twitter">
                        <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
                      </svg>
                    </a>
                  )}
                  {collection.telegram && (
                    <a 
                      href={collection.telegram.startsWith('http') ? collection.telegram : `https://t.me/${collection.telegram}`}
                      target="_blank" 
                      rel="noopener noreferrer"
                      className="flex items-center justify-center w-9 h-9 rounded-full bg-theme-surface hover:bg-theme-primary hover:text-black transition-colors"
                      title="Telegram"
                    >
                      <Send size={16} />
                    </a>
                  )}
                  <button 
                    onClick={handlePageLinkCopy}
                    className="flex items-center justify-center w-9 h-9 rounded-full bg-theme-surface hover:bg-theme-primary hover:text-black transition-colors"
                    title={linkCopied ? "Copied!" : "Share"}
                  >
                    <Share2 size={16} />
                  </button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Tab Navigation - Remove Offers tab */}
      <div className="border-b border-theme-border mb-6">
        <div className="container mx-auto px-4">
          <div className="flex overflow-x-auto">
            <button 
              className={`px-6 py-3 font-medium relative whitespace-nowrap ${currentTab === 'items' ? 'text-theme-primary' : 'text-theme-text-secondary hover:text-theme-text-primary'}`}
              onClick={() => setCurrentTab('items')}
            >
              Items
              {currentTab === 'items' && <div className="absolute bottom-0 left-0 right-0 h-0.5 bg-theme-primary"></div>}
            </button>
            <button 
              className={`px-6 py-3 font-medium relative whitespace-nowrap ${currentTab === 'analytics' ? 'text-theme-primary' : 'text-theme-text-secondary hover:text-theme-text-primary'}`}
              onClick={() => setCurrentTab('analytics')}
            >
              Analytics
              {currentTab === 'analytics' && <div className="absolute bottom-0 left-0 right-0 h-0.5 bg-theme-primary"></div>}
            </button>
            <button 
              className={`px-6 py-3 font-medium relative whitespace-nowrap ${currentTab === 'activity' ? 'text-theme-primary' : 'text-theme-text-secondary hover:text-theme-text-primary'}`}
              onClick={() => setCurrentTab('activity')}
            >
              Activity
              {currentTab === 'activity' && <div className="absolute bottom-0 left-0 right-0 h-0.5 bg-theme-primary"></div>}
            </button>
          </div>
        </div>
      </div>

      {/* Main Content based on selected tab */}
      <div className="px-4 md:px-6 lg:px-8 py-6 pb-24">
        {currentTab === 'items' && (
          <>
            {/* Filter controls - Update handlers to use the new functions */}
            <div className="flex flex-col sm:flex-row justify-between items-center gap-4 mb-6">
              <div className="flex flex-wrap items-center gap-2">
                {/* Sorting buttons - use direct state updates with page reset */}
                <div className="flex items-center gap-1 p-0.5 rounded-lg border border-theme-border bg-theme-surface">
                  <button 
                    onClick={() => {
                      setSortBy('price_low_high');
                      setCurrentPage(1);
                    }}
                    title="Price: Low to High"
                    className={`p-1.5 rounded-md ${sortBy === 'price_low_high' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight'}`}
                  >
                    <ArrowDownNarrowWide size={18} />
                  </button>
                  <button 
                    onClick={() => {
                      setSortBy('price_high_low');
                      setCurrentPage(1);
                    }}
                    title="Price: High to Low"
                    className={`p-1.5 rounded-md ${sortBy === 'price_high_low' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight'}`}
                  >
                    <ArrowUpNarrowWide size={18} />
                  </button>
                  <button 
                    onClick={() => {
                      setSortBy('token_id_asc');
                      setCurrentPage(1);
                    }}
                    title="ID: Low to High"
                    className={`p-1.5 rounded-md ${sortBy === 'token_id_asc' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight'}`}
                  >
                    <ArrowDown01 size={18} />
                  </button>
                  <button 
                    onClick={() => {
                      setSortBy('token_id_desc');
                      setCurrentPage(1);
                    }}
                    title="ID: High to Low"
                    className={`p-1.5 rounded-md ${sortBy === 'token_id_desc' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight'}`}
                  >
                    <ArrowUp01 size={18} />
                  </button>
                </div>
                
                {/* Enhanced search input - use the proper handlers */}
                <div className="flex items-center bg-theme-surface/60 border border-theme-border px-3 py-1.5 rounded-lg">
                  <Search size={16} className="text-theme-text-secondary mr-2" />
                  <input 
                    type="text" 
                    value={searchInputValue}
                    onChange={handleSearchInputChange}
                    onKeyPress={handleSearchKeyPress}
                    placeholder="Search by name or ID... (Press Enter to search)"
                    className="bg-transparent text-sm text-theme-text-primary focus:outline-none w-36 sm:w-48 placeholder-theme-text-secondary/70"
                  />
                  {searchInputValue && (
                    <button 
                      onClick={clearSearch}
                      className="ml-1 text-theme-text-secondary hover:text-theme-primary"
                    >
                      <X size={14} />
                    </button>
                  )}
                </div>

                {/* "Only Listed" Filter Toggle - use direct state updates */}
                <div className="flex items-center gap-2 bg-theme-surface border border-theme-border p-1.5 rounded-lg text-sm">
                  <input 
                    type="checkbox" 
                    id="only-listed-checkbox"
                    checked={showOnlyListed}
                    onChange={(e) => {
                      setShowOnlyListed(e.target.checked);
                      setCurrentPage(1);
                    }}
                    className="h-4 w-4 rounded border-theme-border text-theme-primary focus:ring-theme-primary cursor-pointer"
                  />
                  <label htmlFor="only-listed-checkbox" className="text-theme-text-secondary cursor-pointer select-none">
                    Only Listed
                  </label>
                </div>

                {/* Keep the sweep functionality unchanged */}
                <div className="flex items-center gap-2 bg-theme-surface border border-theme-border p-0.5 rounded-lg">
                  <ShoppingBag size={18} className="ml-1.5 text-theme-text-secondary"/>
                  <input 
                    type="range"
                    min="2"
                    max="10"
                    value={sweepCount}
                    onChange={(e) => {
                      const count = parseInt(e.target.value);
                      setSweepCount(count);
                      
                      if (count > 0) {
                        // Use paginatedNFTs since that's our current display
                        const priceSortedNfts = [...paginatedNFTs]
                          .filter(nft => nft.price !== null && nft.price > 0)
                          .sort((a, b) => (a.price || Infinity) - (b.price || Infinity));
                        
                        const nftsToHighlight = priceSortedNfts.slice(0, count);
                        setSweepHighlightIds(new Set(nftsToHighlight.map(nft => nft.tokenId)));
                        
                        // Auto-calculate estimated total price
                        const estimatedTotal = nftsToHighlight.reduce((sum, nft) => sum + (nft.price || 0), 0);
                        setSweepMaxPrice(estimatedTotal.toFixed(2));
                      } else {
                        setSweepHighlightIds(new Set());
                        setSweepMaxPrice('');
                      }
                    }}
                    className="w-24 h-2 bg-theme-border rounded-lg appearance-none cursor-pointer accent-theme-primary"
                    title={`Sweep ${sweepCount} cheapest items`}
                  />
                  <span className="text-sm text-theme-text-primary w-8 text-center font-medium flex items-center justify-center">
                    {sweepCount} 
                    {sweepCount === 10 && <span className="ml-1">🔥</span>}
                  </span>
                  <button
                    onClick={() => setShowSweepPriceModal(true)}
                    disabled={sweepCount === 0}
                    className="px-4 py-2 rounded-lg bg-theme-primary text-black font-medium hover:bg-theme-primary/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
                  >
                    Confirm Sweep
                  </button>
                </div>
              </div>

              {/* View mode toggle - updated for new approach */}
              <div className="flex items-center gap-2 bg-theme-surface border border-theme-border p-0.5 rounded-lg">
                <button 
                  onClick={() => setViewMode('based')}
                  title="Based View (4 per row)"
                  className={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
                    viewMode === 'based' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight text-theme-text-secondary'
                  }`}
                >
                  Based
                </button>
                <button 
                  onClick={() => setViewMode('compact')}
                  title="Compact View (6 per row)"
                  className={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
                    viewMode === 'compact' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight text-theme-text-secondary'
                  }`}
                >
                  Compact
                </button>
                <button 
                  onClick={() => setViewMode('list')}
                  title="List View"
                  className={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
                    viewMode === 'list' ? 'bg-theme-primary text-black' : 'hover:bg-theme-card-highlight text-theme-text-secondary'
                  }`}
                >
                  List
                </button>
              </div>
            </div>

            {/* NFT Grid - updated for new view modes */}
            {loading ? (
              // Skeleton loaders for better UX during loading
              <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                {Array(36).fill(0).map((_, i) => (
                  <div key={i} className="animate-pulse">
                    <div className="aspect-square bg-theme-card-highlight rounded-xl mb-2"></div>
                    <div className="h-4 bg-theme-card-highlight rounded w-3/4 mb-2"></div>
                    <div className="h-4 bg-theme-card-highlight rounded w-1/2"></div>
                  </div>
                ))}
              </div>
            ) : (
              viewMode === 'list' ? (
                <div className="bg-theme-surface border border-theme-border rounded-lg overflow-hidden">
                  <table className="w-full">
                    <thead className="bg-theme-background">
                      <tr className="border-b border-theme-border">
                        <th className="px-4 py-3 text-left text-sm font-medium text-theme-text-secondary">NFT</th>
                        <th className="px-4 py-3 text-right text-sm font-medium text-theme-text-secondary">Price</th>
                        <th className="px-4 py-3 text-right text-sm font-medium text-theme-text-secondary">Last Sale</th>
                        <th className="px-4 py-3 text-right text-sm font-medium text-theme-text-secondary">Owner</th>
                        <th className="px-4 py-3 text-center text-sm font-medium text-theme-text-secondary">Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {paginatedNFTs.map((nft) => (
                        <tr 
                          key={nft.id} 
                          className={`border-b border-theme-border hover:bg-theme-background/50 transition-colors ${sweepHighlightIds.has(nft.id) ? 'bg-theme-accent/10' : ''}`}>
                          <td className="px-4 py-3">
                            <Link 
                              href={`/nft/${collection.contract}/${nft.tokenId || nft.id}`} 
                              className="flex items-center gap-3"
                            >
                              <div className="w-10 h-10 rounded-lg border border-theme-border overflow-hidden bg-theme-card-highlight">
                                <div 
                                  className="w-full h-full bg-cover bg-center" 
                                  style={{ 
                                    backgroundImage: `url(${nft.image})`,
                                    backgroundSize: 'cover',
                                    backgroundPosition: 'center',
                                  }}
                                />
                              </div>
                              <div>
                                <div className="font-medium text-theme-text-primary">{`#${nft.tokenId || nft.id}`}</div>
                              </div>
                            </Link>
                          </td>
                          <td className="px-4 py-3 text-right text-theme-text-primary">{nft.price ? `${nft.price} BASED` : 'Not Listed'}</td>
                          <td className="px-4 py-3 text-right text-theme-text-secondary">{nft.lastSale ? `${nft.lastSale} BASED` : '-'}</td>
                          <td className="px-4 py-3 text-right">
                            {nft.owner ? (
                              <a 
                                href={`https://explorer.bf1337.org/address/${nft.owner}`}
                                target="_blank"
                                rel="noopener noreferrer"
                                className="text-theme-text-secondary hover:text-theme-primary font-mono text-xs transition-colors"
                                title={nft.owner}
                              >
                                {nft.owner.slice(0, 6)}...{nft.owner.slice(-4)}
                              </a>
                            ) : (
                              <span className="text-theme-text-secondary">-</span>
                            )}
                          </td>
                          <td className="px-4 py-3 text-center">
                            <button className="px-3 py-1 bg-theme-primary text-black text-sm font-medium rounded-lg hover:bg-theme-primary/90 transition-colors" onClick={() => handleNFTInteraction(nft)}>
                              {nft.price ? 'Buy' : 'Make Offer'}
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div className={`grid gap-4 ${
                  viewMode === 'compact' 
                    ? 'grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6' // 6 per row on large screens
                    : 'grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4' // 4 per row on large screens (based view)
                }`}>
                  {paginatedNFTs.map((nft) => (
                    <DirectNFTCard 
                      key={nft.id || nft.tokenId} 
                      id={nft.tokenId || nft.id || 0}
                      tokenId={nft.tokenId || nft.id || 0}
                      name={nft.name || `#${nft.tokenId}`}
                      image={nft.image || `https://picsum.photos/seed/${collection.contract}${nft.tokenId}/500/500`}
                      owner={nft.owner || '0x0000000000000000000000000000000000000000'}
                      isListed={!!nft.price}
                      price={nft.price ? String(nft.price) : undefined}
                      seller={nft.seller}
                      collection={{
                        name: collection.name || '',
                        contract: collection.contract || ''
                      }}
                      contractAddress={collection.contract}
                      compact={viewMode === 'compact'}
                      onInteract={handleNFTInteraction}
                    />
                  ))}
                </div>
              )
            )}

            {/* Pagination - keep existing pagination code unchanged */}
            {!loading && totalPages > 1 && (
              <div className="flex justify-center mt-8">
                <div className="flex items-center gap-2">
                  <button 
                    onClick={() => goToPage(1)}
                    disabled={currentPage === 1}
                    className="px-3 py-1 rounded-md border border-theme-border hover:bg-theme-card-highlight disabled:opacity-50 disabled:hover:bg-transparent"
                  >
                    First
                  </button>
                  <button 
                    onClick={() => goToPage(currentPage - 1)}
                    disabled={currentPage === 1}
                    className="px-3 py-1 rounded-md border border-theme-border hover:bg-theme-card-highlight disabled:opacity-50 disabled:hover:bg-transparent"
                  >
                    Prev
                  </button>
                  
                  <span className="px-3 py-1 text-theme-text-primary">
                    Page {currentPage} of {totalPages} ({totalNFTs} total NFTs)
                  </span>
                  
                  <button 
                    onClick={() => goToPage(currentPage + 1)}
                    disabled={currentPage === totalPages}
                    className="px-3 py-1 rounded-md border border-theme-border hover:bg-theme-card-highlight disabled:opacity-50 disabled:hover:bg-transparent"
                  >
                    Next
                  </button>
                  <button 
                    onClick={() => goToPage(totalPages)}
                    disabled={currentPage === totalPages}
                    className="px-3 py-1 rounded-md border border-theme-border hover:bg-theme-card-highlight disabled:opacity-50 disabled:hover:bg-transparent"
                  >
                    Last
                  </button>
                </div>
              </div>
            )}
          </>
        )}
        
        {currentTab === 'analytics' && <div className="py-10 text-center">Analytics View Coming Soon</div>}
        
        {currentTab === 'activity' && (
          <div>
            <h3 className="text-lg font-semibold mb-4">Recent Activity</h3>
            
            {activityLoading ? (
              <div className="text-center py-8">
                <div className="animate-spin rounded-full h-8 w-8 border-b-2 border-theme-primary mx-auto"></div>
                <p className="text-theme-text-secondary mt-2">Loading activity...</p>
              </div>
            ) : collectionActivity.length > 0 ? (
              <div className="space-y-4">
                {collectionActivity.map((activity, index) => (
                  <div key={activity.id || index} className="bg-theme-surface border border-theme-border rounded-lg p-4">
                    <div className="flex justify-between items-start">
                      <div className="flex-1">
                        <div className="flex items-center gap-3 mb-2">
                          {/* Activity Type Icon */}
                          <div className={`w-8 h-8 rounded-full flex items-center justify-center ${
                            activity.type === 'Sale' ? 'bg-green-100' :
                            activity.type === 'List' ? 'bg-blue-100' :
                            activity.type === 'OfferAccepted' ? 'bg-purple-100' :
                            activity.type === 'OfferCancelled' ? 'bg-red-100' :
                            'bg-gray-100'
                          }`}>
                            {activity.type === 'Sale' ? (
                              <ShoppingBag className={`w-4 h-4 ${
                                activity.type === 'Sale' ? 'text-green-600' : 'text-gray-600'
                              }`} />
                            ) : activity.type === 'List' ? (
                              <Tag className="w-4 h-4 text-blue-600" />
                            ) : activity.type === 'OfferAccepted' ? (
                              <Users className="w-4 h-4 text-purple-600" />
                            ) : activity.type === 'OfferCancelled' ? (
                              <X className="w-4 h-4 text-red-600" />
                            ) : (
                              <Layers className="w-4 h-4 text-gray-600" />
                            )}
                          </div>
                          
                          <div>
                            <p className="font-medium text-theme-text-primary">
                              {activity.type === 'Sale' ? 'Sale' :
                               activity.type === 'List' ? 'Listed' :
                               activity.type === 'OfferAccepted' ? 'Offer Accepted' :
                               activity.type === 'OfferCancelled' ? 'Offer Cancelled' :
                               activity.type}
                              {activity.tokenId && ` - NFT #${activity.tokenId}`}
                            </p>
                            
                            <div className="flex items-center gap-4 text-sm text-theme-text-secondary">
                              {activity.from && (
                                <span>From: {shortenAddress(activity.from)}</span>
                              )}
                              {activity.to && (
                                <span>To: {shortenAddress(activity.to)}</span>
                              )}
                              <span>{activity.date.toLocaleDateString()} at {activity.date.toLocaleTimeString()}</span>
                            </div>
                          </div>
                        </div>
                      </div>
                      
                      {/* Price and Transaction Link */}
                      <div className="text-right">
                        {activity.price && (
                          <p className="font-semibold text-theme-text-primary mb-1">
                            {activity.price}
                          </p>
                        )}
                        
                        <div className="flex gap-2">
                          {activity.tokenId && (
                            <Link 
                              href={`/nft/${activity.nftContract}/${activity.tokenId}`}
                              className="px-2 py-1 bg-theme-primary hover:bg-theme-primary/80 text-black text-xs rounded transition-colors"
                            >
                              View NFT
                            </Link>
                          )}
                          
                          {activity.txHash && (
                            <a 
                              href={`https://explorer.bf1337.org/tx/${activity.txHash}`}
                              target="_blank"
                              rel="noopener noreferrer"
                              className="px-2 py-1 border border-theme-border hover:bg-theme-surface-secondary text-theme-text-primary text-xs rounded transition-colors flex items-center gap-1"
                            >
                              Tx <ExternalLink className="w-3 h-3" />
                            </a>
                          )}
                        </div>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <div className="text-center py-8 text-theme-text-secondary">
                <p>No recent activity found for this collection.</p>
                <p className="mt-2 text-sm">Activity will appear here when sales, listings, and offers occur in this collection.</p>
              </div>
            )}
          </div>
        )}
      </div>

      {/* Sweep Price Modal */}
      {showSweepPriceModal && (
        <div className="fixed inset-0 bg-black/70 backdrop-blur-sm flex items-center justify-center z-50 p-4">
          <div className="bg-theme-surface p-6 rounded-xl shadow-xl border border-theme-border w-full max-w-md">
            <h3 className="text-lg font-semibold text-theme-text-primary mb-1">Sweep {sweepCount} Items</h3>
            {parseFloat(sweepMaxPrice) > 0 && (
              <p className="text-sm text-theme-text-secondary mb-2">
                Estimated total: {parseFloat(sweepMaxPrice).toFixed(2)} BASED
              </p>
            )}
            <p className="text-sm text-theme-text-secondary mb-4">
              This will attempt to purchase the {sweepCount} cheapest available NFTs in this collection.
            </p>
            
            {/* Show items that will be swept */}
            {sweepHighlightIds.size > 0 && (
              <div className="mb-4">
                <h4 className="text-sm font-medium text-theme-text-primary mb-2">Items to sweep:</h4>
                <div className="max-h-32 overflow-y-auto bg-theme-background rounded-lg p-2">
                  {paginatedNFTs
                    .filter(nft => sweepHighlightIds.has(nft.tokenId))
                    .map(nft => (
                      <div key={nft.tokenId} className="flex justify-between text-xs text-theme-text-secondary py-1">
                        <span>{nft.name}</span>
                        <span>{nft.price} BASED</span>
                      </div>
                    ))}
                </div>
              </div>
            )}
            
            <div className="mb-4">
              <label htmlFor="sweep-max-price" className="block text-sm font-medium text-theme-text-secondary mb-1">
                Confirm Max Total Price (BASED)
              </label>
              <input
                type="number"
                id="sweep-max-price"
                value={sweepMaxPrice}
                onChange={(e) => setSweepMaxPrice(e.target.value)}
                placeholder="e.g., 5.75"
                className="w-full px-3 py-2 rounded-lg border border-theme-border bg-theme-background focus:ring-theme-primary focus:border-theme-primary text-theme-text-primary"
              />
            </div>
            
            <div className="flex justify-end gap-3">
              <button
                onClick={() => setShowSweepPriceModal(false)}
                className="px-4 py-2 rounded-lg border border-theme-border hover:bg-theme-card-highlight transition-colors text-theme-text-primary"
              >
                Cancel
              </button>
              <button
                onClick={async () => {
                  const maxPriceNum = parseFloat(sweepMaxPrice);
                  if (!maxPriceNum || maxPriceNum <= 0) {
                    alert('Please set a valid max price');
                    return;
                  }

                  try {
                    // Get cheapest listed NFTs within budget
                    const availableNfts = [...paginatedNFTs]
                      .filter(nft => nft.price !== null && nft.price > 0 && nft.isListed)
                      .sort((a, b) => (a.price || 0) - (b.price || 0));

                    const itemsToSweep = [];
                    let totalCost = 0;
                    
                    for (const nft of availableNfts) {
                      const nftPrice = nft.price || 0;
                      if (totalCost + nftPrice <= maxPriceNum && itemsToSweep.length < sweepCount) {
                        itemsToSweep.push(nft);
                        totalCost += nftPrice;
                      }
                    }

                    if (itemsToSweep.length === 0) {
                      alert('No NFTs found within your budget');
                      return;
                    }

                    console.log(`[Sweep] Attempting to buy ${itemsToSweep.length} NFTs for total: ${totalCost.toFixed(2)} BASED`);
                    
                    // Show confirmation with details
                    const confirmMessage = `Sweep ${itemsToSweep.length} NFTs for ${totalCost.toFixed(2)} BASED?\n\nItems:\n${itemsToSweep.map(nft => `${nft.name}: ${nft.price} BASED`).join('\n')}`;
                    
                    if (!confirm(confirmMessage)) {
                      return;
                    }

                    // For now, simulate the sweep (in production you'd integrate with actual marketplace contract)
                    alert(`Sweep initiated!\n\nTarget: ${itemsToSweep.length} NFTs\nEstimated total: ${totalCost.toFixed(2)} BASED\n\nNote: This is a simulation. In production, this would execute real transactions.`);
                    
                    setShowSweepPriceModal(false);
                    setSweepCount(0);
                    setSweepMaxPrice('');
                    setSweepHighlightIds(new Set());
                    
                  } catch (error) {
                    console.error('[Sweep] Error during sweep operation:', error);
                    alert('Error during sweep operation. Please try again.');
                  }
                }}
                disabled={!sweepMaxPrice || parseFloat(sweepMaxPrice) <= 0}
                className="px-4 py-2 rounded-lg bg-theme-primary text-black font-medium hover:bg-theme-primary/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Execute Sweep
              </button>
            </div>
          </div>
        </div>
      )}

      {/* NFT Interaction Modal */}
      <NFTInteractionModal
        nft={selectedNFT}
        isOpen={isModalOpen}
        onClose={() => {
          setIsModalOpen(false);
          setSelectedNFT(null);
        }}
      />
    </div>
  );
}

export default CollectionPage;